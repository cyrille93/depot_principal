# ───────────────────────────────────────────────────────────
# Variables d'environnement — Rose Annonce
# Copiez ce fichier en ".env" (développement) ou configurez ces
# variables sur votre hébergeur (production). Ne committez jamais .env.
# ───────────────────────────────────────────────────────────

# Base de données PostgreSQL
# Dév (Docker local) :
DATABASE_URL="postgresql://postgres:confiance2026@localhost:5433/confiance?schema=public"
# Prod : utilisez l'URL fournie par votre Postgres managé (Neon, Supabase, RDS…)

# Secret d'authentification (OBLIGATOIRE en production)
# Générez-en un avec :  openssl rand -base64 32
AUTH_SECRET="à_remplacer_par_un_secret_aléatoire"

# URL publique du site (OBLIGATOIRE en production pour le SEO : sitemap, canonical, Open Graph)
# Dév :
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Prod (exemple) :
# NEXT_PUBLIC_SITE_URL="https://roseannonce.cm"

# (À venir) Stockage CDN des photos — à renseigner quand le compte sera créé
# CDN_ENDPOINT=""
# CDN_ACCESS_KEY=""
# CDN_SECRET_KEY=""
# CDN_BUCKET=""

# (À venir) Mobile Money — agrégateur de paiement
# PAYMENT_API_KEY=""
# PAYMENT_WEBHOOK_SECRET=""

# --- CinetPay (Mobile Money) ---
# Récupère ces valeurs dans ton tableau de bord CinetPay (mode test pour le sandbox).
CINETPAY_API_KEY="ta_cle_api_cinetpay"
CINETPAY_SITE_ID="ton_site_id_cinetpay"
# URL publique du site (sert aux URL de notification/retour CinetPay)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
